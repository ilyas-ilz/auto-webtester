# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# playwright mcp / scratch
.playwright-mcp/

# windows crash dumps
*.stackdump

# runtime browser session/cookie state
state.json

# planning scratch docs (keep README/ARCHITECTURE/AGENTS/CLAUDE)
Plan-*.md
Plan.md

# vercel
.vercel

# runtime data — sqlite db, encryption key, run screenshots, visual baselines
/data
/public/shots
/public/traces
/public/baselines

# typescript
*.tsbuildinfo
next-env.d.ts
